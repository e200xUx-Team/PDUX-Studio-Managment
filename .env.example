# ─────────────────────────────────────────────────────────────
# The ePlane Co. — Clay Studio Dashboard
# Copy to .env for local development
# In Vercel: set these under Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Server port (local dev only — Vercel ignores this)
PORT=3000

# JWT signing secret — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Admin accounts — seeded into DB on first run
ADMIN_EMAIL_1=rahul.sp@eplane.ai
ADMIN_NAME_1=Rahul Sakthevel
ADMIN_PASS_1=your-secure-password-here

ADMIN_EMAIL_2=rajan.sunjay@eplane.ai
ADMIN_NAME_2=Rajan Sunjay
ADMIN_PASS_2=your-secure-password-here

# Node environment
NODE_ENV=production
